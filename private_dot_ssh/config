Host boss
  HostName boss.home.arpa
  ForwardAgent yes
  LocalForward 9999 localhost:9999

Host *.home.arpa
  ForwardAgent yes

Host *
  User james
  ControlPath ~/.ssh/%C
  ControlMaster auto
  ControlPersist 15s
  PermitLocalCommand yes
  LocalCommand ~/.scripts/ssh-title.fish %h

# Don't use local agent for inbound SSH sessions.
Match host * exec "test -z $SSH_TTY"
  IdentityAgent ~/.1password/agent.sock
