{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "lsp": false,
  "provider": {
    "fractal-internal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fractal",
      "options": {
        "baseURL": "http://fractal.home.arpa:8001/v1"
      },
      "models": {
        "default": {
          "name": "Qwen3.5 35B-A3B (local)",
          "limit": {
            "context": 131072,
            "output": 65536,
          },
        },
      },
    },
  },
  "plugin": ["@plannotator/opencode@latest"],
}
