{
  "meta": {
    "name": "pi",
    "version": "1.0.0",
    "description": "Pi coding agent"
  },
  "security": {
    "groups": [
      "go_runtime",
      "nix_runtime",
      "python_runtime",
      "rust_runtime"
    ]
  },
  "filesystem": {
    "allow": [
      "/tmp",
      "~/.bun",
      "~/.cache/gleam",
      "~/.cache/go-build",
      "~/.cache/goimports",
      "~/.cache/gopls",
      "~/.cache/uv",
      "~/.config/go",
      "~/.npm",
      "~/.pi"
    ],
    "read": [
      "/etc"
    ],
    "write": [],
    "allow_file": [],
    "read_file": [
      "/proc/sys/vm/overcommit_memory",
      "/proc/version_signature",
      "~/.cvsignore",
      "~/.gitconfig"
    ],
    "write_file": []
  },
  "network": {
    "block": false
  },
  "workdir": {
    "access": "readwrite"
  }
}
