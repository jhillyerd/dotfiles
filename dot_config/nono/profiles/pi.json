{
  "meta": {
    "name": "pi",
    "version": "1.0.0",
    "description": "Pi coding agent"
  },
  "security": {
    "groups": [
      "git_config",
      "go_runtime",
      "nix_runtime",
      "node_runtime",
      "python_runtime",
      "rust_runtime",
      "user_caches_linux"
    ]
  },
  "filesystem": {
    "allow": [
      "/tmp",
      "~/.bun",
      "~/.config/go",
      "~/.npm",
      "~/.pi",
      "~/go"
    ],
    "read": [
      "/etc",
      "~/.local/share/gh/extensions"
    ],
    "allow_file": [],
    "read_file": [
      "/proc/sys/vm/overcommit_memory",
      "/proc/version_signature",
      "~/.config/gh/config.yml",
      "~/.config/gh/hosts.yml",
      "~/.cvsignore"
    ]
  },
  "network": {
    "block": false
  },
  "workdir": {
    "access": "readwrite"
  }
}
